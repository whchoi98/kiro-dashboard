# kiro-dashboard — Environment Variables Template
# Copy this file to .env.local for local development
# Production values are set in infra/lib/ecs-stack.ts

# ---------------------------------------------------------------
# AWS Configuration
# ---------------------------------------------------------------

# AWS region for Athena, Glue, Bedrock, and IdentityStore
AWS_REGION=us-east-1

# CDK deployment region (ap-northeast-2 for Seoul)
CDK_DEFAULT_REGION=ap-northeast-2

# AWS account ID for CDK deployments
# CDK_DEFAULT_ACCOUNT=123456789012

# ---------------------------------------------------------------
# Athena / Glue
# ---------------------------------------------------------------

# Glue database name containing Kiro usage tables
ATHENA_DATABASE=titanlog

# S3 bucket path where Athena stores query results
ATHENA_OUTPUT_BUCKET=s3://your-bucket-name/athena-results/

# Primary Glue table name (date format: YYYY-MM-DD)
GLUE_TABLE_NAME=user_report

# Secondary per-user analytics table (date format: MM-DD-YYYY)
# GLUE_USER_ANALYTIC_TABLE=by_user_analytic

# ---------------------------------------------------------------
# IAM Identity Center
# ---------------------------------------------------------------

# Identity Store ID (find in AWS console → IAM Identity Center)
IDENTITY_STORE_ID=d-xxxxxxxxxxxx

# ---------------------------------------------------------------
# NextAuth.js (Authentication)
# ---------------------------------------------------------------

# Base URL of the application (no trailing slash)
# Local: http://localhost:3000
# Production: https://your-cloudfront-domain.cloudfront.net
NEXTAUTH_URL=http://localhost:3000

# Random secret for NextAuth session signing
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-generate-a-real-secret

# ---------------------------------------------------------------
# Cognito OAuth (if using Cognito provider)
# ---------------------------------------------------------------

# COGNITO_CLIENT_ID=your-cognito-client-id
# COGNITO_CLIENT_SECRET=your-cognito-client-secret
# COGNITO_ISSUER=https://cognito-idp.<region>.amazonaws.com/<user-pool-id>

# ---------------------------------------------------------------
# Application
# ---------------------------------------------------------------

# Bind address for Next.js server
HOSTNAME=0.0.0.0

# Node environment
NODE_ENV=development
